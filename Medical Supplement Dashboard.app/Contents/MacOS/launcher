#!/bin/bash
# Medical Supplement Dashboard Launcher
PROJ_DIR="/Users/wielkikrzychmbp/Documents/medical-supplement-advisor"
VENV_PYTHON="$PROJ_DIR/.venv/bin/python"

# Check venv exists
if [ ! -f "$VENV_PYTHON" ]; then
    osascript -e 'display dialog "Błąd: Nie znaleziono .venv\n\nŚcieżka: '"$VENV_PYTHON"'\n\nUruchom w Terminalu:\ncd '"$PROJ_DIR"'\npip install -r requirements.txt" with title "Medical Supplement Dashboard" buttons {"OK"} default button 1 with icon stop'
    exit 1
fi

# Show file picker via AppleScript
FILE=$(osascript << 'APPLESCRIPT_EOF'
tell application "System Events"
    activate
end tell
set theFile to choose file with prompt "Wybierz plik z wynikami badań krwi:" of type {"json", "pdf", "docx"} default location (path to documents folder)
return POSIX path of theFile
APPLESCRIPT_EOF
)

# User cancelled
if [ -z "$FILE" ]; then
    exit 0
fi

# Determine file type and run
EXT="${FILE##*.}"

# Kill any existing server on port 8000
lsof -ti:8000 | xargs kill 2>/dev/null

case "$EXT" in
    json)
        "$VENV_PYTHON" "$PROJ_DIR/run.py" --json "$FILE" --web --no-browser --port 8000 &
        ;;
    pdf|docx|doc)
        "$VENV_PYTHON" "$PROJ_DIR/run.py" --document "$FILE" --web --no-browser --port 8000 &
        ;;
    *)
        osascript -e "display dialog \"Nieobsługiwany format: .$EXT\nObsługiwane: JSON, PDF, DOCX\" with title \"Medical Supplement Dashboard\" buttons {\"OK\"} default button 1 with icon caution"
        exit 1
        ;;
esac

SERVER_PID=$!

# Wait for server to start, then open browser
for i in $(seq 1 30); do
    if curl -s http://127.0.0.1:8000/health > /dev/null 2>&1; then
        open "http://127.0.0.1:8000"
        break
    fi
    sleep 0.5
done

# Show notification
osascript -e "display notification \"Dashboard gotowy\" with title \"Medical Supplement Dashboard\""

# Wait for server
wait $SERVER_PID
