#!/bin/bash
# Medical Supplement Dashboard Launcher
# Opens file picker, starts web dashboard

DIR="$(cd "$(dirname "$0")/../.." && pwd)"
VENV_PYTHON="$DIR/.venv/bin/python"

# Check venv exists
if [ ! -f "$VENV_PYTHON" ]; then
    osascript -e 'display dialog "Błąd: Nie znaleziono .venv. Uruchom pip install -r requirements.txt" with title "Medical Supplement Dashboard" buttons {"OK"} default button 1 with icon stop'
    exit 1
fi

# Show file picker via AppleScript
FILE=$(osascript -e '
tell application "System Events"
    activate
end tell
set theFile to choose file with prompt "Wybierz plik z wynikami badań krwi:" of type {"json", "pdf", "docx"} default location (path to documents folder)
return POSIX path of theFile
' 2>/dev/null)

# User cancelled
if [ -z "$FILE" ]; then
    exit 0
fi

# Determine file type and run
EXT="${FILE##*.}"
case "$EXT" in
    json)
        "$VENV_PYTHON" "$DIR/run.py" --json "$FILE" --web --no-browser --port 8000 &
        ;;
    pdf|docx)
        "$VENV_PYTHON" "$DIR/run.py" --document "$FILE" --web --no-browser --port 8000 &
        ;;
    *)
        osascript -e "display dialog \"Nieobsługiwany format: .$EXT\\nObsługiwane: JSON, PDF, DOCX\"" 
        exit 1
        ;;
esac

SERVER_PID=$!

# Wait for server to start, then open browser
for i in {1..20}; do
    if curl -s http://127.0.0.1:8000/health > /dev/null 2>&1; then
        open "http://127.0.0.1:8000"
        break
    fi
    sleep 0.5
done

# Keep Terminal open to show server status
echo ""
echo "🧪 Medical Supplement Dashboard"
echo "================================"
echo "📡 Serwer: http://127.0.0.1:8000"
echo "📄 Plik: $FILE"
echo ""
echo "Naciśnij Ctrl+C aby zatrzymać serwer"
echo ""

# Wait for server
wait $SERVER_PID
